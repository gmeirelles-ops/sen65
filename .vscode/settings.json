{
    "idf.port": "/dev/ttyUSB0",
    "idf.flashType": "UART",
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.path": "clangd", 
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--query-driver=/sdk/tools/**/bin/*-gcc",
        "--header-insertion=never",
        "--background-index",
        "--log=verbose"
    ]
}